<docinfo xmlns:xi="http://www.w3.org/2001/XInclude">

	<author-biographies length="short" />

	<brandlogo url="http://www.ualberta.ca/augustana/" source="images/UA_Logo_Stk_Green_RGB.png" />

	<!-- Prefix to enhance Sage notebook contents -->
	<initialism>EF</initialism>

	<!-- this is the default, but supresses a warning -->
	<cross-references text="type-global" />

	<math-package latex-name="cancel" mathjax-name="cancel" />

	<macros> <xi:include href="./latex-macros.tex" parse="text" /> </macros>

	<!-- tikz package and libraries for images -->
	<latex-image-preamble>
		\usepackage{cancel}
		\usepackage{tikz}
		\usepackage{tikz-3dplot}
		\usepackage{tikz-cd}
		\usetikzlibrary{matrix}
		\usetikzlibrary{positioning}
		\usetikzlibrary{fit}
		\usetikzlibrary{decorations.pathreplacing}
	</latex-image-preamble>

	<!-- part="structural" resets chapter numbering at beginning of new part -->
<!--
	<numbering>
		<division part="decorative" />
	</numbering>
-->

	<!-- renamings -->
	<rename element="problem">Worked Example</rename>
	<rename element="identity">Procedure</rename>
	<rename element="claim">Test</rename>
	<rename element="worksheet">Activities</rename>
	<rename element="insight">Question</rename> <!-- <insight> is RemarkLike, <question> is ExampleLike -->
	<rename element="hypothesis">Idea</rename>
	<!-- <rename element="heuristic">Goal</rename>
	<rename element="convention">Pattern</rename>   BEFORE USING: check whether I have actually used the convention tag for its original intended purpose
	<rename element="activity">Discovery</rename> -->

</docinfo>
