<exercises xml:id="exercises-multinomial">
<title>Exercises</title>

<exercise><p>
	Choose numbers <m> x,y </m> so that the equality in the <xref ref="theorem-multinomial-binomial" text="title" /> becomes
	<md> \sum_{k=0}^n \binom{n}{k}\, 2^k = 3^n </md>.
</p></exercise>

<exercise xml:id="exercise-multinomial-binomial-formula-counting-subsets">
<!-- \label{EXERCISE::multinomial::binomial.formula.counting.subsets} -->
	<task xml:id="exercise-multinomial-binomial-formula-counting-subsets-choose-numbers"><p>
	<!-- \label{EXERCISE::multinomial::binomial.formula.counting.subsets::choose.numbers} -->
		Choose numbers <m> x,y </m> so that the equality in the <xref ref="theorem-multinomial-binomial" text="title" /> becomes
		<md>
			\binom{n}{0} \;\;-\;\;
			\binom{n}{1} \;\;+\;\;
			\binom{n}{2} \;\;-\;\;
			\binom{n}{3} \;\;+\;\;
			\dotsb \;\;+\;\;
			(-1)^n \binom{n}{n} \;\;=\;\;
			0
		</md>.
	</p></task>
	<task>
		<statement>
			<p>
			The equality from
			<xref ref="exercise-multinomial-binomial-formula-counting-subsets-choose-numbers" text="type-local" />
			can be rearranged to yield
			<md>
				<mrow>
					\binom{n}{0} \;\;+\;\;
					\binom{n}{2} \;\;+\;\;
					\binom{n}{4} \;\;+\;\;
					\dotsb \;\;+\;\;
					\binom{n}{m_1}
				</mrow><mrow>
					\;\;=\;\;
					\binom{n}{1} \;\;+\;\;
					\binom{n}{3} \;\;+\;\;
					\binom{n}{5} \;\;+\;\;
					\dotsb \;\;+\;\;
					\binom{n}{m_2}
				</mrow>
			</md>,
			where
			<md><mrow>
				m_1 \amp = \begin{cases}
					n, \amp n\text{ even}, \\
					n-1, \amp n\text{ odd}, \\
				\end{cases}
				\amp
				m_2 \amp = \begin{cases}
					n-1, \amp n\text{ even}, \\
					n, \amp n\text{ odd}. \\
				\end{cases}
			</mrow></md>
			</p><p>
			What does this rearranged formula tell you about the subsets of a set of size <m> n </m>?
			</p>
		</statement>
		<hint><p> What is the sum on the left counting? What is the sum on the right counting? </p></hint>
	</task>
</exercise>

</exercises>
